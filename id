local autofarm = true
local autoCollectingCubes = true
local autoClaimRewards = true
local farmMoving = false
local showMap = false
local autoeat = false

local mainUI = UI:NewWindow("Eat the World")
local autoSection = mainUI:NewSection("Auto")

-- ===================== AUTO FARM =====================
local function startAutoFarm()
    coroutine.wrap(function()
        local text = Drawing.new("Text")
        text.Outline = true
        text.OutlineColor = Color3.new(0, 0, 0)
        text.Color = Color3.new(1, 1, 1)
        text.Position = Vector2.new(64, 64)
        text.Size = 14
        text.Visible = true

        local bedrock = Instance.new("Part")
        bedrock.Anchored = true
        bedrock.Size = Vector3.new(2048, 10, 2048)
        bedrock.Position = Vector3.new(0, -5, 0)
        bedrock.Parent = workspace

        local function onChar(char)
            local hum = char:WaitForChild("Humanoid")
            local root = char:WaitForChild("HumanoidRootPart")
            local events = char:WaitForChild("Events")

            local eat = events:WaitForChild("Eat")
            local grab = events:WaitForChild("Grab")
            local sell = events:WaitForChild("Sell")

            local conn
            conn = game:GetService("RunService").Heartbeat:Connect(function()
                if not autofarm then
                    conn:Disconnect()
                    return
                end

                hum:ChangeState(Enum.HumanoidStateType.Physics)
                root.Anchored = false

                grab:FireServer()
                eat:FireServer()

                if char.Size.Value >= LocalPlayer.Upgrades.MaxSize.Value then
                    sell:FireServer()
                end

                root.CFrame = CFrame.new(0, 5, 0)
            end)

            hum.Died:Connect(function()
                if conn then conn:Disconnect() end
            end)
        end

        if LocalPlayer.Character then
            onChar(LocalPlayer.Character)
        end

        LocalPlayer.CharacterAdded:Connect(onChar)

        while autofarm do
            task.wait()
        end

        text:Destroy()
        bedrock:Destroy()
    end)()
end

-- ===================== AUTO COLLECT =====================
local function startAutoCollect()
    coroutine.wrap(function()
        while autoCollectingCubes do
            task.wait()
            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                for _, v in workspace:GetChildren() do
                    if v.Name == "Cube" then
                        v.CFrame = root.CFrame
                    end
                end
            end
        end
    end)()
end

-- ===================== AUTO CLAIM =====================
local function startAutoClaim()
    coroutine.wrap(function()
        while autoClaimRewards do
            task.wait(1)
            for _, reward in LocalPlayer.TimedRewards:GetChildren() do
                if reward.Value > 0 then
                    Events.RewardEvent:FireServer(reward)
                end
            end
            Events.SpinEvent:FireServer()
        end
    end)()
end

-- ===================== UI =====================
autoSection:CreateToggle("Auto farm", function(v)
    autofarm = v
    if v then startAutoFarm() end
end)

autoSection:CreateToggle("Auto collect", function(v)
    autoCollectingCubes = v
    if v then startAutoCollect() end
end)

autoSection:CreateToggle("Auto claim", function(v)
    autoClaimRewards = v
    if v then startAutoClaim() end
end)

autoSection:CreateToggle("Move mode", function(v)
    farmMoving = v
end)

autoSection:CreateToggle("Show map", function(v)
    showMap = v
end)

autoSection:CreateToggle("Auto eat", function(v)
    autoeat = v
end)

-- ===================== AUTO START =====================
-- Start everything ON by default
startAutoFarm()
startAutoCollect()
startAutoClaim()
